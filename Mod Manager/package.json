{
  "name": "ModManager",
  "version": "1.0.0",
  "author": "Atampy26",
  "private": true,
  "description": "Mod manager for the Simple Mod Framework.",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build:win",
    "build:all": "npm run typecheck && electron-vite build",
    "build:win": "npm run typecheck && electron-vite build && electron-builder --win --dir",
    "build:mac": "npm run typecheck && electron-vite build && electron-builder --mac",
    "build:linux": "npm run typecheck && electron-vite build && electron-builder --linux --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run svelte-check",
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "lint": "eslint --cache .",
    "postinstall": "electron-builder install-app-deps"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=7"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/remote": "^2.0.8",
    "@fortawesome/free-regular-svg-icons": "^6.1.2",
    "@fortawesome/free-solid-svg-icons": "^6.1.2",
    "adm-zip": "^0.5.9",
    "ajv": "^8.11.0",
    "ansi-to-html": "^0.7.2",
    "autoprefixer": "^10.4.8",
    "axios": "^0.27.2",
    "carbon-components-svelte": "^0.67.8",
    "carbon-icons-svelte": "^11.2.0",
    "chalk": "^4.1.2",
    "electron-context-menu": "^2.5.2",
    "electron-serve": "^1.1.0",
    "electron-updater": "^6.3.9",
    "electron-window-state": "^5.0.3",
    "filtrex": "^3.0.0",
    "fs-extra": "^10.1.0",
    "hash-wasm": "^4.9.0",
    "json5": "^2.2.2",
    "klaw-sync": "^6.0.0",
    "lodash.chunk": "^4.2.0",
    "lodash.get": "^4.4.2",
    "lodash.isequal": "^4.5.0",
    "lodash.memoize": "^4.1.2",
    "lodash.mergewith": "^4.6.2",
    "marked": "^4.0.18",
    "md5": "^2.3.0",
    "postcss": "^8.4.16",
    "rehype-stringify": "^9.0.3",
    "sanitize-html": "^2.7.3",
    "semver": "^7.3.7",
    "shiki": "^0.11.1",
    "svelte-fa": "^2.4.0",
    "svelte-tippy": "^1.3.2",
    "tailwindcss": "^3.1.8",
    "tippy.js": "^6.3.7",
    "unified": "^10.1.2",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@sveltejs/adapter-static": "1.0.0-next.50",
    "@sveltejs/kit": "^1.25.1",
    "@sveltejs/vite-plugin-svelte": "^2.5.3",
    "@types/adm-zip": "^0.5.0",
    "@types/electron-window-state": "^2.0.34",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash.isequal": "^4.5.6",
    "@types/lodash.memoize": "^4.1.7",
    "@types/lodash.mergewith": "^4.6.7",
    "@types/marked": "^4.0.3",
    "@types/node": "^22.19.1",
    "@types/sanitize-html": "^2.6.2",
    "@types/uuid": "^8.3.4",
    "concurrently": "^7.3.0",
    "cross-env": "^7.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^2.33.2",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "sass": "^1.54.4",
    "svelte": "^4.2.1",
    "svelte-check": "^3.5.2",
    "svelte-preprocess": "^5.0.4",
    "typescript": "^5",
    "vite": "^4"
  }
}
