{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": false,
    "moduleResolution": "Bundler",
    "composite": false,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts"
  ]
}
