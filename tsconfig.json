{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./build/compiled",
        "allowJs": true,
        "target": "ES2019",
        "module": "CommonJS",
        "esModuleInterop": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "sourceMap": true,
        "inlineSources": true,
        "sourceRoot": "/",
        "noEmitHelpers": true,
        "importHelpers": true,
        "declaration": true,
        "resolveJsonModule": true
    },
    "include": [
        "./src/**/*"
    ]
}